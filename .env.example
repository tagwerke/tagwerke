# Postgres connection string (Neon / Supabase / Railway / local docker / Dokploy DB).
DATABASE_URL=postgres://user:password@host:5432/do_app

# Secret used to sign session cookies. Use a long random string in production,
# e.g. `openssl rand -base64 48`.
SESSION_SECRET=change-me-to-a-long-random-string

# Backend server port. In dev the Vite proxy targets this; in prod the platform
# (Dokploy/Traefik) routes external traffic to it.
PORT=5174

# Set to "production" in deployment. Enables Secure cookies and makes the server
# serve the built SPA from dist/. (nixpacks.toml sets this automatically.)
# NODE_ENV=production
