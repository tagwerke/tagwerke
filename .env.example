# Copy to `.env` and fill in. The same file works for `docker compose` and for
# running the server directly with `npm run start`.

# ── Required ──────────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Use a long random string in production,
# e.g. `openssl rand -base64 48`.
SESSION_SECRET=change-me-to-a-long-random-string

# ── Docker Compose self-host (recommended) ────────────────────────────────────
# The compose stack builds DATABASE_URL from these. Set at least POSTGRES_PASSWORD.
POSTGRES_USER=tagwerke
POSTGRES_PASSWORD=change-me-to-a-strong-db-password
POSTGRES_DB=tagwerke
# Host port the app is published on (container always listens on 5174).
APP_PORT=5174

# ── Running the server directly (without compose) ─────────────────────────────
# Only needed if you are NOT using docker compose. Point at any Postgres
# (local, Neon, Supabase, Railway, Dokploy DB, …). Compose ignores this and
# builds its own DATABASE_URL from the POSTGRES_* vars above.
# DATABASE_URL=postgres://user:password@host:5432/tagwerke
# PORT=5174
# NODE_ENV=production

# ── Workspace + links ─────────────────────────────────────────────────────────
# Shown in the app; defaults to "Workspace".
# ORG_NAME=Acme
# Public base URL — used to build password-reset links in emails.
# APP_URL=https://tagwerke.example.com

# ── Backups ───────────────────────────────────────────────────────────────────
# Automatic daily backups are ON by default: the app dumps its whole database to
# ./backups/ (full pg_dump, all tables) and prunes old ones. Nothing is uploaded
# anywhere — copying backups off-site is up to you. These settings also apply to
# the manual scripts (scripts/backup.sh, scripts/restore-drill.sh).
#
# Recommended: encrypt every backup with age (https://age-encryption.org —
# `age-keygen` makes a key pair). RECIPIENT is the public key (safe to keep
# here); IDENTITY is the path to the secret key file, needed only to run the
# restore drill / restore. Keep the identity file OFF this server (password
# manager / offline copy) — anyone holding it can read your backups.
# BACKUP_AGE_RECIPIENT=age1...
# BACKUP_AGE_IDENTITY=/root/tagwerke-backup-key.txt
# How many dumps to keep locally (older ones are pruned).
# BACKUP_KEEP=14
# Where backups are written (default ./backups). Point at a mounted disk if
# you want them on separate storage.
# BACKUP_DIR=backups
# Opt out ONLY if you run your own database backup pipeline (pgBackRest,
# volume snapshots, ...). You are then responsible for your own backups.
# BACKUP_DISABLED=true

# ── Email (password reset / 2FA) ──────────────────────────────────────────────
# Point at Amazon SES SMTP in an EU region (eu-west-1 / eu-central-1) for data
# residency, or any SMTP server. If unset, reset emails are logged to the server
# console in dev and FAIL in production.
#   1. SES console → verify a sender domain/address (for MAIL_FROM)
#   2. SES console → SMTP settings → Create SMTP credentials (gives USER + PASS)
#   3. Request production access (new SES accounts start in sandbox)
# SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false            # true for port 465
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=no-reply@example.com

# ── Web push (notifications) ──────────────────────────────────────────────────
# Enables browser/desktop/phone push for the notifications feature. Generate a
# keypair once with:  npx web-push generate-vapid-keys
# The PUBLIC key is exposed to the browser; the PRIVATE key must stay secret. If
# these are unset, in-app notifications still work — only device push is disabled.
# Changing them invalidates every existing device subscription (users re-enable).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:no-reply@example.com
